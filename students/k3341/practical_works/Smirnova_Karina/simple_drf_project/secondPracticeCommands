# Найти всех водителей с именем “Имя1”
Owner.objects.filter(first_name='Имя1')

# Взяв любого случайного владельца получить его id, и по этому id получить экземпляр удостоверения в виде объекта модели
# (можно в 2 запроса)
random_owner = Owner.objects.order_by('?').first()
owner_id = random_owner.id
licenses = License.objects.filter(owner_id=owner_id)
print(licenses)

# Вывести всех владельцев красных машин
owners_of_red_cars = Owner.objects.filter(cars__color='красный').distinct()
print(owners_of_red_cars)

# Найти всех владельцев, чей год владения машиной начинается с 2010
from django.db.models.functions import ExtractYear
owners_2025 = Owner.objects.annotate(start_year=ExtractYear('ownerships__start_date')).filter(start_year=2025).distinct()
print(owners_2025)